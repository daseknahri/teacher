DATABASE_URL=sqlite:///app.db
STORAGE_DIR=./storage
AUTH_TOKEN_TTL_HOURS=24
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOG_LEVEL=INFO
LOG_JSON=true
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=7
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_ON_5XX=true
ALERT_ON_EXCEPTION=true
ALERT_SLOW_MS=2500
ALERT_MIN_INTERVAL_SECONDS=300
ALERT_TIMEOUT_SECONDS=10
MAX_EXCEL_UPLOAD_BYTES=5242880
MAX_SCREENSHOT_UPLOAD_BYTES=10485760
UPLOAD_RATE_LIMIT_COUNT=10
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
EXPORT_RATE_LIMIT_COUNT=20
EXPORT_RATE_LIMIT_WINDOW_SECONDS=60
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OCR_LANG=fra+eng
UNIT_PLANNER_PROVIDER=openai
SESSION_WRITER_PROVIDER=fallback
NOTEBOOKLM_HOME=
NOTEBOOKLM_AUTH_PATH=
NOTEBOOKLM_PROFILE=default
NOTEBOOKLM_TIMEOUT_SECONDS=45
NOTEBOOKLM_KEEPALIVE_SECONDS=0
NOTEBOOKLM_NOTEBOOK_PREFIX=Teacher Progress - 
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=true
# Optional PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://teacher:teacher@localhost:5432/teacher_progress
# Optional NotebookLM production example:
# UNIT_PLANNER_PROVIDER=notebooklm
# SESSION_WRITER_PROVIDER=notebooklm
# NOTEBOOKLM_HOME=/data/notebooklm
# NOTEBOOKLM_PROFILE=default
# Optional: path to official NotesCC template used for principal export
# PRINCIPAL_EXPORT_TEMPLATE=C:\Users\user\Downloads\export_notesCC_2APIC-3_0019.xlsx
